{
  "manifest_version": 3,
  "name": "Attend Browser Bridge",
  "version": "1.2",
  "description": "Captures text selections and sends them to attend for narration context.",
  "key": "",
  "permissions": ["nativeMessaging"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
