{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "attend hook post-tool-use --agent claude",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "attend hook pre-tool-use --agent claude",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "attend hook session-end --agent claude",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "attend hook session-start --agent claude",
            "type": "command"
          }
        ],
        "matcher": "startup|clear|compact"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "attend hook stop --agent claude",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "attend hook user-prompt --agent claude",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ]
  }
}
